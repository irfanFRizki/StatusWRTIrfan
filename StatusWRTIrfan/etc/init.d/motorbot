#!/bin/sh /etc/rc.common
# Motor Maintenance Telegram Bot Init Script for OpenWrt
# Copyright (C) 2024

START=99
STOP=10

USE_PROCD=1

PROG=/usr/bin/python3
SCRIPT_PATH=/root/motor_bot.py
WORK_DIR=/root
PID_FILE=/var/run/motorbot.pid

start_service() {
    # Pastikan direktori kerja ada
    [ -d "$WORK_DIR" ] || mkdir -p "$WORK_DIR"
    
    # Pastikan file script ada
    if [ ! -f "$SCRIPT_PATH" ]; then
        echo "Error: Script not found at $SCRIPT_PATH"
        return 1
    fi
    
    # Pastikan Python3 terinstall
    if [ ! -x "$PROG" ]; then
        echo "Error: Python3 not found at $PROG"
        return 1
    fi
    
    echo "Starting Motor Bot..."
    echo "Working directory: $WORK_DIR"
    echo "Script path: $SCRIPT_PATH"
    
    procd_open_instance
    procd_set_param command $PROG $SCRIPT_PATH
    procd_set_param pidfile $PID_FILE
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param user root
    procd_set_param file $SCRIPT_PATH
    
    # PENTING: Set working directory
    procd_set_param directory $WORK_DIR
    
    # Set environment variables
    procd_set_param env HOME=$WORK_DIR
    procd_append_param env PATH=/usr/bin:/bin:/usr/sbin:/sbin
    procd_append_param env PYTHONUNBUFFERED=1
    
    procd_close_instance
    
    echo "Motor Bot started successfully"
    echo "Check logs: logread -f | grep motor"
    echo "Debug log: cat $WORK_DIR/bot_debug.log"
}

stop_service() {
    echo "Stopping Motor Bot..."
}

reload_service() {
    stop
    sleep 2
    start
}

service_triggers() {
    procd_add_reload_trigger "motorbot"
}

status() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "Motor Bot is running (PID: $PID)"
            echo "Uptime: $(ps -o etime= -p $PID 2>/dev/null | tr -d ' ')"
            echo "Memory: $(ps -o rss= -p $PID 2>/dev/null | tr -d ' ') KB"
            echo ""
            echo "Log files:"
            echo "  System log: logread | grep motor"
            echo "  Debug log: cat $WORK_DIR/bot_debug.log"
            echo "  Data file: cat $WORK_DIR/data_motor.json"
            return 0
        else
            echo "Motor Bot is not running (stale PID file)"
            rm -f "$PID_FILE"
            return 1
        fi
    else
        echo "Motor Bot is not running"
        return 1
    fi
}