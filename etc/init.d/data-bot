#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

PROG=/usr/bin/python3
BOT_SCRIPT=/opt/data-bot/bot.py
PID_FILE=/var/run/data-bot.pid

BOT_USER="data-bot"
BOT_GROUP="data-bot"

start_service() {
    [ -f "$BOT_SCRIPT" ] || {
        echo "Bot script not found: $BOT_SCRIPT"
        return 1
    }
    
    procd_open_instance
    procd_set_param user $BOT_USER
    procd_set_param command $PROG $BOT_SCRIPT
    procd_set_param env HOME=/opt/data-bot
    procd_set_param env PATH=/usr/bin:/bin:/usr/sbin:/sbin
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 5
    procd_set_param pidfile $PID_FILE
    procd_set_param limits core="0 0"
    procd_set_param limits nofile="1024 1024"
    procd_close_instance
    
    echo "Telegram bot started"
}

stop_service() {
    echo "Stopping Telegram bot..."
    if [ -f "$PID_FILE" ]; then
        PID=$(cat $PID_FILE)
        if [ -n "$PID" ]; then
            kill $PID 2>/dev/null
            sleep 2
            kill -9 $PID 2>/dev/null
        fi
        rm -f $PID_FILE
    fi
}
